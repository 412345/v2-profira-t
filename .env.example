# ---- Supabase (Lovable Cloud auto-injects these in Lovable; copy to Vercel env) ----
VITE_SUPABASE_URL="https://YOUR-PROJECT-REF.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="eyJhbGciOi..."
VITE_SUPABASE_PROJECT_ID="YOUR-PROJECT-REF"

# Server-side mirrors (used inside server functions / SSR)
SUPABASE_URL="https://YOUR-PROJECT-REF.supabase.co"
SUPABASE_PUBLISHABLE_KEY="eyJhbGciOi..."
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOi..."   # server-only, never expose
SUPABASE_PROJECT_ID="YOUR-PROJECT-REF"

# ---- Resend (approval emails) ----
RESEND_API_KEY="re_..."
RESEND_FROM_ADDRESS="PROFIRA <noreply@yourdomain.com>"

# ---- Public site URL used in transactional email links ----
PUBLIC_SITE_URL="https://your-vercel-deployment.vercel.app"

# ---- Company bank details shown to investors at the payment step ----
# These are publishable (rendered in the browser); fill them with the actual
# PROFIRA collection account before going live.
